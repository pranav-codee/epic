# ============ EPIC v1 — Backend Configuration ============
# Copy to .env and fill in real values. Never commit .env.

APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# 32+ random bytes recommended in prod (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-in-prod

# --- Database ---
# Dev (default): SQLite. Production: on-prem MS SQL Server.
DATABASE_URL=sqlite:///./epic_dev.db
# DATABASE_URL=mssql+pyodbc://EPIC_APP:CHANGE_ME@sqlhost:1433/EPIC?driver=ODBC+Driver+18+for+SQL+Server

# --- Authentication ---
# AUTH_PROVIDER: "mock" (dev only) or "entra" (production).
AUTH_PROVIDER=mock
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
ENTRA_SCOPES=openid profile email User.Read

# --- Notifications (Microsoft Teams Incoming Webhook) ---
# TODO (EPL IT): Provide the real EPL Teams Incoming Webhook URL before pilot rollout (TBD-3).
TEAMS_WEBHOOK_URL=
TEAMS_NOTIFICATIONS_ENABLED=true

# --- Attachments ---
ATTACHMENT_DIR=./storage/attachments
ATTACHMENT_MAX_BYTES=26214400          # 25 MB
ATTACHMENT_BLOCKED_EXTENSIONS=.exe,.bat,.ps1,.js,.msi,.cmd,.vbs

# --- Bootstrap ---
# Comma-separated emails that receive SYSTEM_ADMIN on first login.
BOOTSTRAP_ADMIN_EMAILS=cara.admin@epl.local
